# ============================================================
# .env - Konfigurasi Environment
# Rename file ini menjadi .env lalu isi nilainya
# JANGAN di-commit ke Git!
# ============================================================

# === MAYAR ===
MAYAR_API_KEY=isi_api_key_mayar_kamu_disini
WEBHOOK_SECRET=isi_webhook_secret_kamu_disini

# === MIKROTIK ===
MIKROTIK_HOST=192.168.1.1        # IP address Mikrotik kamu
MIKROTIK_PORT=8728               # 8728 = API standar, 8729 = API SSL
MIKROTIK_USER=admin              # Username login Mikrotik
MIKROTIK_PASS=passwordmikrotik   # Password login Mikrotik

# === SERVER ===
PORT=3000
